+    float    savedXA = gfx_current_dimensions.x_adjust_ratio;
+    gfx_current_dimensions.width  = (uint32_t)eyeW;
+    gfx_current_dimensions.height = (uint32_t)eyeH;
+    gfx_current_dimensions.aspect_ratio = (float)eyeW / (float)eyeH;
