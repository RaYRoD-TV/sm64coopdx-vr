+            rendering_state.scissor.y = 0;
+            rendering_state.scissor.width  = gfx_current_dimensions.width;
+            rendering_state.scissor.height = gfx_current_dimensions.height;
+            gfx_run_dl(gVrSkyDomeGfx);
+            gVrInSkyDome = false;
+        }
